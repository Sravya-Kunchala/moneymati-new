// Prisma schema for storing appointment bookings
// Provider: PostgreSQL (set DATABASE_URL in your environment)

generator client {
  provider = "prisma-client-js"
  output   = "../generated/client"
}

datasource db {
  provider = "postgresql"
}
model Appointment {
  id               String   @id @default(cuid())
  fullName         String
  email            String
  phone            String?
  datetime         DateTime
  timezone         String?    // optional timezone identifier (e.g. Asia/Kolkata)
  durationMinutes  Int?       @default(30)
  status           AppointmentStatus @default(PENDING)
  source           String?    // where the booking originated (hero, profile, admin)
  notes            String?    // user-provided notes
  calendarEventId  String?    // external calendar event id if created
  metadata         Json?      // flexible JSON payload
  createdAt        DateTime   @default(now())
  updatedAt        DateTime   @updatedAt
  userId           String?    // optional reference to internal user
}

enum AppointmentStatus {
  PENDING
  CONFIRMED
  CANCELLED
  COMPLETED
}
model User {
  id            String    @id
  name          String
  email         String    @unique
  emailVerified Boolean   @default(false)
  password      String?
  image         String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  sessions      Session[]
  accounts      Account[]
}

model Session {
  id        String   @id
  expiresAt DateTime
  token     String   @unique
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  ipAddress String?
  userAgent String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Account {
  id                    String    @id
  accountId             String
  providerId            String
  userId                String
  user                  User      @relation(fields: [userId], references: [id])
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt
}

model Verification {
  id         String    @id
  identifier String
  value      String
  expiresAt  DateTime
  ipAddress  String?
  userAgent  String?
  createdAt  DateTime?
  updatedAt  DateTime?
}

model BlogPost {
  id          String   @id @default(cuid())
  title       String
  slug        String   @unique
  excerpt     String?
  content     String
  coverImage  String?
  authorId    String?
  published   Boolean  @default(false)
  publishedAt DateTime?
  tags        String[] @default([])
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

enum WebinarStatus {
  UPCOMING
  LIVE
  COMPLETED
}

model Webinar {
  id          String        @id @default(cuid())
  title       String
  host        String
  scheduledAt DateTime
  status      WebinarStatus @default(UPCOMING)
  thumbType   String?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
}

model Ebook {
  id          String   @id @default(cuid())
  title       String
  description String?
  category    String   @default("Financials")
  pages       Int      @default(0)
  format      String   @default("PDF")
  href        String?
  status      String   @default("Published")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}
